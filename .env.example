# 環境変数テンプレート
# このファイルをコピーして .env を作成し、必要な値を設定してください。
# .env は .gitignore 済みなので Git に含まれません。
#
# 使い方:
#   cp .env.example .env
#   vim .env  # 必要な値を設定

# ========================================
# UID/GID 設定（Docker コンテナ用）
# ========================================
# コンテナ内で作成したファイルの権限問題を回避するため、
# ホストの UID/GID と一致させます。
# 確認方法: id -u && id -g
#
# デフォルトは 1000:1000 です。異なる場合のみ設定してください。
# USER_ID=1000
# GROUP_ID=1000

# ========================================
# Kaggle API 認証（必須）
# ========================================
# ホストとDockerコンテナの両方で使用します。
# ~/.kaggle/kaggle.json は不要です（この設定で完結します）。
#
# 取得方法: Kaggle → Account → API → Create New API Token
# kaggle.json の内容: {"username":"your_username","key":"xxxxxxxx..."}
# 下記に username と key の値を設定してください。
KAGGLE_USERNAME=your_username
KAGGLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
